    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-1111-2222-3333-444455556666}</ProjectGuid>
    <RootNamespace>WindowsEReader</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <ProjectName>WindowsEReader</ProjectName>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <PropertyGroup>
    <IncludePath>$(ProjectDir)src\include;$(IncludePath)</IncludePath>
    <!-- Pin a single build tree for every configuration/platform so neither a
         command-line nor a Visual Studio build can scatter stray output and
         intermediate folders at the project root. -->
    <OutDir>$(ProjectDir)build\bin\$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(ProjectDir)build\obj\$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>
  <!-- Debug build: full diagnostics, no optimization. Built WITHOUT the CRT. -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <CompileAs>CompileAsC</CompileAs>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>false</SDLCheck>
      <PreprocessorDefinitions>WIN32_LEAN_AND_MEAN;UNICODE;_UNICODE;_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <Optimization>Disabled</Optimization>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
      <!-- No CRT: disable every feature whose helper lives in the C runtime. -->
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
      <SupportJustMyCode>false</SupportJustMyCode>
      <ControlFlowGuard>false</ControlFlowGuard>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
      <EntryPointSymbol>EReaderEntryPoint</EntryPointSymbol>
      <AdditionalDependencies>kernel32.lib;user32.lib;gdi32.lib;shell32.lib;shlwapi.lib;ole32.lib;uuid.lib;windowscodecs.lib;comdlg32.lib;comctl32.lib;dwmapi.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <!-- Release build: optimize aggressively for SIZE per project requirement.
       Built WITHOUT the CRT. -->
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <CompileAs>CompileAsC</CompileAs>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>false</SDLCheck>
      <PreprocessorDefinitions>WIN32_LEAN_AND_MEAN;UNICODE;_UNICODE;NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- /O1 minimize size, /Os favor size, /Gy + /GF for COMDAT/string pooling. -->
      <Optimization>MinSpace</Optimization>
      <FavorSizeOrSpace>Size</FavorSizeOrSpace>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <StringPooling>true</StringPooling>
      <IntrinsicFunctions>false</IntrinsicFunctions>
      <WholeProgramOptimization>true</WholeProgramOptimization>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <!-- No CRT: disable every feature whose helper lives in the C runtime. -->
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <ControlFlowGuard>false</ControlFlowGuard>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <LinkTimeCodeGeneration>UseLinkTimeCodeGeneration</LinkTimeCodeGeneration>
      <GenerateDebugInformation>false</GenerateDebugInformation>
      <IgnoreAllDefaultLibraries>true</IgnoreAllDefaultLibraries>
      <EntryPointSymbol>EReaderEntryPoint</EntryPointSymbol>
      <AdditionalDependencies>kernel32.lib;user32.lib;gdi32.lib;shell32.lib;shlwapi.lib;ole32.lib;uuid.lib;windowscodecs.lib;comdlg32.lib;comctl32.lib;dwmapi.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="src\source\main.c" />
    <ClCompile Include="src\source\platform.c" />
    <ClCompile Include="src\source\application.c" />
    <ClCompile Include="src\source\window.c" />
    <ClCompile Include="src\source\archive.c" />
    <ClCompile Include="src\source\inflate.c" />
    <ClCompile Include="src\source\document.c" />
    <ClCompile Include="src\source\renderer.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="src\include\ereader.h" />
    <ClInclude Include="src\include\platform.h" />
    <ClInclude Include="src\include\application.h" />
    <ClInclude Include="src\include\window.h" />
    <ClInclude Include="src\include\archive.h" />
    <ClInclude Include="src\include\inflate.h" />
    <ClInclude Include="src\include\document.h" />
    <ClInclude Include="src\include\renderer.h" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
